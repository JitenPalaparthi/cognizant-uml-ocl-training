@startuml
title Employee and Payment with OCL

interface Payable {
  +calculatePay(): double
  +generatePayslip(): String
}

enum EmployeeType {
  FULL_TIME
  PART_TIME
  CONTRACT
}

enum Department {
  ENGINEERING
  HR
  FINANCE
  SALES
}

abstract class Employee {
  -id: int
  -name: String
  -email: String
  -department: Department
  -employeeType: EmployeeType

  +Employee(id: int, name: String, email: String)
  +getId(): int
  +getName(): String
  +getEmail(): String
  +setEmail(email: String): void
  +getDepartment(): Department
  +setDepartment(department: Department): void
  +abstract calculateBonus(): double
}

class FullTimeEmployee {
  -monthlySalary: double
  -bonusPercentage: double

  +FullTimeEmployee(id: int, name: String, email: String, salary: double)
  +calculatePay(): double
  +calculateBonus(): double
  +generatePayslip(): String
}

class PartTimeEmployee {
  -hourlyRate: double
  -hoursWorked: int

  +PartTimeEmployee(id: int, name: String, email: String, hourlyRate: double)
  +addHours(hours: int): void
  +calculatePay(): double
  +calculateBonus(): double
  +generatePayslip(): String
}

class ContractEmployee {
  -contractAmount: double
  -contractDurationMonths: int

  +ContractEmployee(id: int, name: String, email: String, amount: double)
  +calculatePay(): double
  +calculateBonus(): double
  +generatePayslip(): String
}

class PayrollService {
  +processPayroll(employee: Payable): void
  +printPayslip(employee: Payable): void
}

Employee <|-- FullTimeEmployee
Employee <|-- PartTimeEmployee
Employee <|-- ContractEmployee

Payable <|.. FullTimeEmployee
Payable <|.. PartTimeEmployee
Payable <|.. ContractEmployee

Employee --> Department
Employee --> EmployeeType

PayrollService ..> Payable

note bottom
=========================
OCL CONSTRAINTS
=========================

-- =========================================================
-- Employee Basic Invariants
-- =========================================================

context Employee
inv IdMustBePositive:
    self.id > 0

context Employee
inv NameMustNotBeEmpty:
    self.name <> null and self.name.size() > 0

context Employee
inv NameMinimumLength:
    self.name.size() >= 2

context Employee
inv NameMaximumLength:
    self.name.size() <= 100

context Employee
inv EmailMustNotBeEmpty:
    self.email <> null and self.email.size() > 0

context Employee
inv EmailMinimumLength:
    self.email.size() >= 5

context Employee
inv EmailMustContainAtSymbol:
    self.email.indexOf('@') > 0

context Employee
inv EmailMustContainDot:
    self.email.indexOf('.') > 0

context Employee
inv DepartmentMustExist:
    self.department <> null

context Employee
inv EmployeeTypeMustExist:
    self.employeeType <> null

context Employee
inv UniqueEmployeeId:
    Employee.allInstances()->isUnique(e | e.id)

context Employee
inv UniqueEmployeeEmail:
    Employee.allInstances()->isUnique(e | e.email)


-- =========================================================
-- Employee Type and Subclass Matching
-- =========================================================

context FullTimeEmployee
inv FullTimeTypeMustMatch:
    self.employeeType = EmployeeType::FULL_TIME

context PartTimeEmployee
inv PartTimeTypeMustMatch:
    self.employeeType = EmployeeType::PART_TIME

context ContractEmployee
inv ContractTypeMustMatch:
    self.employeeType = EmployeeType::CONTRACT

context Employee
inv FullTimeEmployeeMustHaveFullTimeType:
    self.oclIsTypeOf(FullTimeEmployee) implies
    self.employeeType = EmployeeType::FULL_TIME

context Employee
inv PartTimeEmployeeMustHavePartTimeType:
    self.oclIsTypeOf(PartTimeEmployee) implies
    self.employeeType = EmployeeType::PART_TIME

context Employee
inv ContractEmployeeMustHaveContractType:
    self.oclIsTypeOf(ContractEmployee) implies
    self.employeeType = EmployeeType::CONTRACT


-- =========================================================
-- FullTimeEmployee Rules
-- =========================================================

context FullTimeEmployee
inv MonthlySalaryMustBePositive:
    self.monthlySalary > 0

context FullTimeEmployee
inv MonthlySalaryMinimum:
    self.monthlySalary >= 10000

context FullTimeEmployee
inv MonthlySalaryMaximum:
    self.monthlySalary <= 1000000

context FullTimeEmployee
inv BonusPercentageMustBeValid:
    self.bonusPercentage >= 0 and self.bonusPercentage <= 100

context FullTimeEmployee
inv CalculatePayReturnsMonthlySalary:
    self.calculatePay() = self.monthlySalary

context FullTimeEmployee
inv BonusCalculation:
    self.calculateBonus() =
        self.monthlySalary * self.bonusPercentage / 100

context FullTimeEmployee
inv BonusCannotExceedSalary:
    self.calculateBonus() <= self.monthlySalary

context FullTimeEmployee
inv PayslipMustNotBeEmpty:
    self.generatePayslip() <> null and self.generatePayslip().size() > 0


-- =========================================================
-- PartTimeEmployee Rules
-- =========================================================

context PartTimeEmployee
inv HourlyRateMustBePositive:
    self.hourlyRate > 0

context PartTimeEmployee
inv HourlyRateMinimum:
    self.hourlyRate >= 100

context PartTimeEmployee
inv HourlyRateMaximum:
    self.hourlyRate <= 10000

context PartTimeEmployee
inv HoursWorkedCannotBeNegative:
    self.hoursWorked >= 0

context PartTimeEmployee
inv HoursWorkedMaximumLimit:
    self.hoursWorked <= 240

context PartTimeEmployee
inv CalculatePayReturnsHourlyPay:
    self.calculatePay() =
        self.hourlyRate * self.hoursWorked

context PartTimeEmployee
inv ZeroHoursMeansZeroPay:
    self.hoursWorked = 0 implies self.calculatePay() = 0

context PartTimeEmployee
inv PartTimeBonusIsZero:
    self.calculateBonus() = 0

context PartTimeEmployee
inv PayslipMustNotBeEmpty:
    self.generatePayslip() <> null and self.generatePayslip().size() > 0


-- =========================================================
-- ContractEmployee Rules
-- =========================================================

context ContractEmployee
inv ContractAmountMustBePositive:
    self.contractAmount > 0

context ContractEmployee
inv ContractAmountMinimum:
    self.contractAmount >= 10000

context ContractEmployee
inv ContractAmountMaximum:
    self.contractAmount <= 10000000

context ContractEmployee
inv ContractDurationMustBePositive:
    self.contractDurationMonths > 0

context ContractEmployee
inv ContractDurationMaximumLimit:
    self.contractDurationMonths <= 60

context ContractEmployee
inv CalculatePayReturnsContractAmount:
    self.calculatePay() = self.contractAmount

context ContractEmployee
inv MonthlyContractValueMustBePositive:
    self.contractAmount / self.contractDurationMonths > 0

context ContractEmployee
inv ContractBonusIsZero:
    self.calculateBonus() = 0

context ContractEmployee
inv PayslipMustNotBeEmpty:
    self.generatePayslip() <> null and self.generatePayslip().size() > 0


-- =========================================================
-- Payable Interface Rules
-- =========================================================

context Payable
inv PayMustNotBeNegative:
    self.calculatePay() >= 0

context Payable
inv PayslipMustNotBeEmpty:
    self.generatePayslip() <> null and
    self.generatePayslip().size() > 0


-- =========================================================
-- Department-Based Rules
-- =========================================================

context Employee
inv FinanceEmployeesMustNotBeContract:
    self.department = Department::FINANCE implies
    self.employeeType <> EmployeeType::CONTRACT

context Employee
inv HREmployeesMustNotBePartTime:
    self.department = Department::HR implies
    self.employeeType <> EmployeeType::PART_TIME

context Employee
inv SalesEmployeesMustHaveEmail:
    self.department = Department::SALES implies
    self.email <> null and self.email.size() > 0


-- =========================================================
-- Employee Constructor
-- =========================================================

context Employee::Employee(id: int, name: String, email: String)
pre ValidId:
    id > 0

pre ValidName:
    name <> null and name.size() > 0

pre ValidEmail:
    email <> null and email.indexOf('@') > 0

post IdAssigned:
    self.id = id

post NameAssigned:
    self.name = name

post EmailAssigned:
    self.email = email


-- =========================================================
-- Employee Getter and Setter Contracts
-- =========================================================

context Employee::getId(): int
post ReturnsId:
    result = self.id

context Employee::getName(): String
post ReturnsName:
    result = self.name

context Employee::getEmail(): String
post ReturnsEmail:
    result = self.email

context Employee::setEmail(email: String)
pre ValidEmail:
    email <> null and email.indexOf('@') > 0

post EmailUpdated:
    self.email = email

context Employee::getDepartment(): Department
post ReturnsDepartment:
    result = self.department

context Employee::setDepartment(department: Department)
pre ValidDepartment:
    department <> null

post DepartmentUpdated:
    self.department = department


-- =========================================================
-- FullTimeEmployee Constructor and Operations
-- =========================================================

context FullTimeEmployee::FullTimeEmployee(id: int, name: String, email: String, salary: double)
pre ValidSalary:
    salary > 0

post SalaryAssigned:
    self.monthlySalary = salary

post EmployeeTypeAssigned:
    self.employeeType = EmployeeType::FULL_TIME

context FullTimeEmployee::calculatePay(): double
post ReturnsMonthlySalary:
    result = self.monthlySalary

context FullTimeEmployee::calculateBonus(): double
post ReturnsPercentageBonus:
    result = self.monthlySalary * self.bonusPercentage / 100

context FullTimeEmployee::generatePayslip(): String
post PayslipGenerated:
    result <> null and result.size() > 0


-- =========================================================
-- PartTimeEmployee Constructor and Operations
-- =========================================================

context PartTimeEmployee::PartTimeEmployee(id: int, name: String, email: String, hourlyRate: double)
pre ValidHourlyRate:
    hourlyRate > 0

post HourlyRateAssigned:
    self.hourlyRate = hourlyRate

post InitialHoursZero:
    self.hoursWorked = 0

post EmployeeTypeAssigned:
    self.employeeType = EmployeeType::PART_TIME

context PartTimeEmployee::addHours(hours: int)
pre HoursMustBePositive:
    hours > 0

pre TotalHoursMustBeWithinLimit:
    self.hoursWorked + hours <= 240

post HoursAdded:
    self.hoursWorked = self.hoursWorked@pre + hours

context PartTimeEmployee::calculatePay(): double
post ReturnsHourlyPay:
    result = self.hourlyRate * self.hoursWorked

context PartTimeEmployee::calculateBonus(): double
post ReturnsZeroBonus:
    result = 0

context PartTimeEmployee::generatePayslip(): String
post PayslipGenerated:
    result <> null and result.size() > 0


-- =========================================================
-- ContractEmployee Constructor and Operations
-- =========================================================

context ContractEmployee::ContractEmployee(id: int, name: String, email: String, amount: double)
pre ValidContractAmount:
    amount > 0

post ContractAmountAssigned:
    self.contractAmount = amount

post EmployeeTypeAssigned:
    self.employeeType = EmployeeType::CONTRACT

context ContractEmployee::calculatePay(): double
post ReturnsContractAmount:
    result = self.contractAmount

context ContractEmployee::calculateBonus(): double
post ReturnsZeroBonus:
    result = 0

context ContractEmployee::generatePayslip(): String
post PayslipGenerated:
    result <> null and result.size() > 0


-- =========================================================
-- PayrollService Operation Contracts
-- =========================================================

context PayrollService::processPayroll(employee: Payable)
pre EmployeeMustNotBeNull:
    employee <> null

pre PayMustBePositive:
    employee.calculatePay() > 0

post PayrollProcessed:
    true

context PayrollService::printPayslip(employee: Payable)
pre EmployeeMustNotBeNull:
    employee <> null

pre PayslipMustExist:
    employee.generatePayslip() <> null and
    employee.generatePayslip().size() > 0

post PayslipPrinted:
    true

end note

@enduml
